{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://rs-backend-3vbq.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://rs-backend-3vbq.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/index.html"
    }
  ]
}
